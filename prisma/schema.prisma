datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ═══════════════════════════════════════
// USERS & AUTH (NextAuth.js models)
// ═══════════════════════════════════════

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // bcrypt hash — null for OAuth users
  role          String    @default("user")  // "user" | "admin"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  credits       Credits?
  jobs          Job[]
  reports       Report[]
  subscriptions Subscription[]
  usage         Usage[]

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ═══════════════════════════════════════
// CREDITS & BILLING
// ═══════════════════════════════════════

model Credits {
  id             String   @id @default(cuid())
  userId         String   @unique
  balance        Int      @default(0)
  lifetimeEarned Int      @default(0)
  lifetimeSpent  Int      @default(0)
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String
  stripeCustomerId     String    @unique
  stripeSubscriptionId String    @unique
  stripePriceId        String
  plan                 String    // "starter" | "pro" | "team"
  status               String    // "active" | "canceled" | "past_due" | "trialing"
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  canceledAt           DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([stripeCustomerId])
}

model Usage {
  id           String   @id @default(cuid())
  userId       String
  reportType   String   // "industry_report" | "datapack"
  creditsUsed  Int
  jobId        String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

// ═══════════════════════════════════════
// JOBS & REPORTS
// ═══════════════════════════════════════

model Job {
  id               String    @id @default(cuid())
  userId           String
  reportType       String    // "industry_report" | "datapack"
  query            String    @db.Text
  config           Json      // { depth, regions, sections, competitorCount }
  status           String    @default("queued")  // "queued" | "processing" | "completed" | "failed"
  currentStep      Int       @default(0)
  currentStepName  String?
  progressPct      Int       @default(0)
  errorMessage     String?   @db.Text
  estimatedCredits Int
  actualCredits    Int?
  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  report Report?

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model Report {
  id         String   @id @default(cuid())
  jobId      String   @unique
  userId     String
  reportType String   // "industry_report" | "datapack"
  query      String   @db.Text
  title      String?

  // Industry Report — array of { id, title, content, keyTable, chartSpec, citations }
  sections   Json?

  // Datapack — array of { name, columns, rows }
  sheets     Json?

  // Shared metadata
  metadata   Json?    // { marketSize, cagr, generatedAt, qualityScore, keyFindings[], sources[] }

  // Enrichment data
  enrichment Json?    // Social + tech intelligence

  // Sizing output
  sizing     Json?    // { topDown, bottomUp, validatedMarketSize, cagr, confidenceInterval }

  // Export files (base64 or file path)
  pdfPath    String?
  xlsxPath   String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([jobId])
  @@index([createdAt])
}

// ═══════════════════════════════════════
// AUDIT LOG
// ═══════════════════════════════════════

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String   // "generate_report" | "download_pdf" | "download_xlsx" | "stripe_checkout" | etc.
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}
